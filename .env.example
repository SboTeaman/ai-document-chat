# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:5173
# Production: set a trusted proxy IP list so X-Forwarded-For is honoured for audit logs.
# TRUSTED_PROXY_IPS=10.0.0.1,10.0.0.2

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kb_user:kb_password@db:5432/knowledgebase
# docker-compose db service uses these directly:
POSTGRES_DB=knowledgebase
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=kb_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── S3 / MinIO ───────────────────────────────────────────────────────────────
# Local dev only. Change before exposing to any network.
# MINIO_ROOT_* seed the minio container; AWS_* must match them.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET_NAME=knowledge-base-files
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1
# Production: remove AWS_S3_ENDPOINT_URL and use real AWS credentials

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_MAX_RETRIES=3

# ─── Document processing ──────────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
EMBEDDING_BATCH_SIZE=100
# How long (seconds) per-chunk embeddings are cached so a retried ingest can
# resume instead of re-embedding the whole document. Should comfortably exceed
# the worst-case retry backoff for a single document.
EMBEDDING_CHECKPOINT_TTL=3600
MAX_UPLOAD_SIZE_MB=20
MAX_CHUNKS_PER_DOCUMENT=5000
WORKSPACE_STORAGE_QUOTA_MB=2048

# ─── Search ───────────────────────────────────────────────────────────────────
SEARCH_VECTOR_WEIGHT=0.7
SEARCH_FTS_WEIGHT=0.3
SEARCH_MIN_SCORE=0.15
# PostgreSQL full-text-search configuration. MUST match the language baked into
# the functional GIN index in documents migration 0003 (default 'english') — a
# mismatch makes the planner skip the index (slower, but results stay correct).
# Changing this to e.g. 'simple' requires a new migration rebuilding the index.
SEARCH_FTS_LANGUAGE=english
QUERY_EMBEDDING_CACHE_TTL=300

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Production: use RS256 with separate private/public keys
JWT_ALGORITHM=HS256
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATELIMIT_ENABLE=True
