# Build context is ./backend — keep the image lean and free of host artifacts.

# Host-installed packages compiled for the local machine (must NOT shadow the
# pip-installed deps inside the image).
.local/

# Collected static is regenerated by `collectstatic` at container start.
staticfiles/

# Secrets / local env (env_file injects these at runtime instead).
.env
.env.*
!.env.example

# Python caches & artifacts
__pycache__/
*.py[cod]
*.so
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Tests are run via a mounted volume, not from the image.
tests/

# VCS / IDE
.git/
.gitignore
.vscode/
.idea/
